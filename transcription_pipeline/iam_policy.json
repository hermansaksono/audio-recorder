{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAudioAndTranscripts",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": [
        "arn:aws:s3:::storycraft-audio-bucket/recordings/*",
        "arn:aws:s3:::storycraft-audio-bucket/transcripts/*"
      ]
    },
    {
      "Sid": "WriteTranscripts",
      "Effect": "Allow",
      "Action": ["s3:PutObject"],
      "Resource": "arn:aws:s3:::storycraft-audio-bucket/transcripts/*"
    },
    {
      "Sid": "RunTranscribeJobs",
      "Effect": "Allow",
      "Action": [
        "transcribe:StartTranscriptionJob",
        "transcribe:GetTranscriptionJob",
        "transcribe:DeleteTranscriptionJob"
      ],
      "Resource": "*"
    },
    {
      "Sid": "UpdateSessionItem",
      "Effect": "Allow",
      "Action": ["dynamodb:UpdateItem"],
      "Resource": "arn:aws:dynamodb:us-east-2:*:table/micro-narrative-story-app-database"
    }
  ]
}
